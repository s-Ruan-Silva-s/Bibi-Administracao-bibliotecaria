        </div>
        </div>
        <nav class="home-area-main-panel-nav">
          <input type="search" placeholder="procurar nome" />
          <button>Novo(a) leitor(a)</button>
        </nav>
        <div class="home-area-main-panel-table-container">
          <table>
            <thead>
              <colgroup>
                <col style="width: 30%" />
                <col style="width: 30%" />
                <col style="width: 20%" />
                <col style="width: 5%" />
                <col style="width: 15%" />
              </colgroup>
            </thead>
            <thead>
              <tr>
                <th>nome</th>
                <th>email</th>
                <th>função</th>
                <th>empréstimo</th>
