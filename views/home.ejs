            </thead>
            <tbody>
              <tr>
                <td>O Cortiço</td>
                <td>Aluísio Azevedo</td>
                <td>Romance</td>
                <td>2</td>
                <td>
                  <button>[Excluir]</button>
                  <button>[editar]</button>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
      <section class="home-area-main-panel" id="users">
        <div class="panel-cadastro">
          <form action="">
              <label for="" class="gfp1">Título</label>
