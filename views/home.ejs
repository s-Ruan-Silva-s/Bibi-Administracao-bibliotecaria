<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon" href="/img/logo.png" type="image/x-icon" />
    <title>Bibi home</title>
  </head>
  <body>
    <header class="home-area-header">
      <div class="home-area-header-content">
        <h1>Bibi</h1>
        <figure>
          <img src="/img/ru.jpeg" alt="user" />
        </figure>
      </div>
    </header>
    <main class="home-area-main">
      <section class="home-area-main-sec-card" data-panel="livros">
        <h1>LIVROS</h1>
        <div class="home-dados">9455</div>
      </section>
      <section class="home-area-main-sec-card" data-panel="users">
        <h1>USUÁRIOS</h1>
        <div class="home-dados">10</div>
      </section>
      <section class="home-area-main-sec-card" data-panel="emprestimos">
        <h1>EMPRÉSTIMOS</h1>
        <div class="home-dados">100</div>
      </section>
      <section class="home-area-main-panel ativo" id="livros">
        <div class="panel-cadastro" id="areaCadLivros">
          <form action="">
            <label for="" class="gfp1">Título</label>
            <input type="text" class="gfp5" />
            <label for="" class="gfp2">Autor</label>
            <input type="text" class="gfp6" />
            <label for="" class="gfp3">Categoria</label>
            <input type="text" class="gfp7" />
            <label for="" class="gfp4">quantidade</label>
            <input type="number" class="gfp8" placeholder="num máximo: 999"/>
            <input type="submit" class="gfp9 cadastrar">
            <button class="gfp 10close" onclick="fecharCadastroLivros()">fechar</button>
          </form>
        </div>
        <nav class="home-area-main-panel-nav">
          <input type="search" />
          <button onclick="exibirCadastroLivros()" id="btnLivro">
            Novo livro
          </button>
        </nav>
        <div class="home-area-main-panel-table-container">
          <table>
            <thead>
              <colgroup>
                <col style="width: 30%" />
                <col style="width: 30%" />
                <col style="width: 20%" />
                <col style="width: 5%" />
                <col style="width: 15%" />
              </colgroup>
            </thead>
            <thead>
              <tr>
                <th>título</th>
                <th>autor</th>
                <th>categoria</th>
                <th>quantidade</th>
                <th>ações</th>
